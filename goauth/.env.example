# Goauth Configuration

# Server
APP_SERVER_PORT=3000
APP_SERVER_HOST=0.0.0.0
APP_SERVER_ENVIRONMENT=development
APP_SERVER_APPURL=http://localhost:3000
# APP_SERVER_BASEPATH=           # 子路径部署，如 /auth
APP_SERVER_TIMEZONE=UTC
# APP_SERVER_COOKIEDOMAIN=       # Cookie 作用域域名
APP_SERVER_COOKIESECURE=auto     # auto/true/false
APP_SERVER_COOKIESAMESITE=lax    # strict/lax/none
# APP_SERVER_CORSALLOWORIGINS=   # CORS 允许来源，逗号分隔
APP_SERVER_RATELIMIT=100         # 速率限制（次/分钟，0=禁用）

# Database
APP_DATABASE_PATH=./data/goauth.db

# OIDC
# APP_OIDC_ISSUER=               # 默认使用 APP_SERVER_APPURL
APP_OIDC_ACCESSTOKENTTL=15       # Access Token 有效期（分钟）
APP_OIDC_IDTOKENTTL=30           # ID Token 有效期（分钟）
APP_OIDC_REFRESHTOKENTTL=168     # Refresh Token 有效期（小时，默认7天）
APP_OIDC_SESSIONTTL=2160         # OIDC Session 有效期（小时，默认90天）

# Session (单位：小时)
APP_SESSION_TTL=24               # 普通登录 Session TTL
APP_SESSION_TTLREMEMBER=720      # "记住我" Session TTL (720h = 30天)

# Security
# APP_SECURITY_CRYPTOKEY=        # 自动生成，无需手动设置
APP_SECURITY_PASSWORDMIN=8
APP_SECURITY_PASSWORDMINSCORE=3
APP_SECURITY_LOGINMAXATTEMPTS=10
APP_SECURITY_LOGINBLOCKDURATION=30  # 封禁时长（分钟）
APP_SECURITY_TOTPMAXATTEMPTS=5      # TOTP 最大尝试次数
APP_SECURITY_AUDITLOGRETENTION=90   # 审计日志保留天数
APP_SECURITY_LOGINATTEMPTCLEANUP=24 # 登录尝试清理间隔（小时）

# UI
APP_UI_APPNAME=Goauth
APP_UI_APPCOLOR=#906bc7
APP_UI_SIGNUPENABLED=true

# Logging
APP_LOGGING_LEVEL=info